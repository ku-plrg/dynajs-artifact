#!/usr/bin/env bash
# ExpoSE analyseScript backed by dynajs concolic (drop-in replacement for
# scripts/play). The Distributor spawns this as `dynajs-play <target> <inputJSON>`
# and reads EXPOSE_OUT_PATH / EXPOSE_COVERAGE_PATH, which Spawn.js puts in our
# environment. We forward to the dynajs instrumenter + Concolic analysis;
# ConcolicAnalysis.endExecution writes those two result files on exit.
#
# Select it with: EXPOSE_PLAY_SCRIPT=scripts/dynajs-play
set -uo pipefail

DYNAJS_HOME="${DYNAJS_HOME:-$HOME/dynajs}"

# ExpoSE root (this script lives in ExpoSE/scripts/).
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

TARGET="$1"
INPUT="${2:-}"
if [ -z "$INPUT" ]; then INPUT='{"_bound":0}'; fi

# ExpoSE's Distributor passes AHG targets relative to Analyser/ -- scripts/play
# runs `cd Analyser` first, so e.g. "../lib/Harness/src/harness.js" resolves to
# ExpoSE/lib/... . dynajs-play does NOT cd there, so a relative target would
# resolve against the Distributor's cwd (ExpoSE root) and miss. Resolve a
# relative target against Analyser/ to an absolute path; absolute ones pass through.
case "$TARGET" in
  /*) ;;
  *)  TARGET="$(cd "$ROOT/Analyser" && cd "$(dirname "$TARGET")" && pwd)/$(basename "$TARGET")" ;;
esac

# dynajs instruments only files under cwd or an --include root; ExpoSE targets
# live outside the dynajs repo, so include the target's directory explicitly.
TARGET_DIR="$(cd "$(dirname "$TARGET")" && pwd)"

# The corpus does `require("S$")`. Resolve it to dynajs's bridge (mapping
# S$.symbol/assume/… onto the Concolic analysis) ahead of ExpoSE's own lib/S$ by
# prepending its parent to NODE_PATH, and --include it so the bridge's
# assume/assert branches are instrumented (visible as path conditions).
SDOLLAR_HOME="$DYNAJS_HOME/analyses/concolic/expose"
export NODE_PATH="$SDOLLAR_HOME${NODE_PATH:+:$NODE_PATH}"

export DYNAJS_HOME
# --pos persist writes the id->location table into each instrumented file so
# D$.ids is populated regardless of CJS/ESM (memory mode no-ops the merge for
# ESM); ConcolicAnalysis reads it to build the statement-coverage payload the
# Distributor aggregates (without it Total Coverage prints NaN%).
export DYNAJS_OPTIONS="--analysis=$DYNAJS_HOME/analyses/dist/Concolic.mjs --partial --pos persist --include $TARGET_DIR --include $SDOLLAR_HOME/S\$"

# The input JSON is the last argv entry, the ExpoSE convention ConcolicAnalysis
# reads via process.argv (mirrors Analyser.js).
exec "$DYNAJS_HOME/dynajs" node "$TARGET" "$INPUT"
